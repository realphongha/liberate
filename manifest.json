{
  "manifest_version": 3,
  "name": "Translate Anyway",
  "version": "1.0.0",
  "description": "Enable browser translation on websites that disable translation.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/scanner.js",
        "src/content/observer.js",
        "src/content/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Translate Anyway"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
